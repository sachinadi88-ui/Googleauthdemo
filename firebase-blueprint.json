{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile state containing public identity fields",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique Firebase Authentication User ID"
        },
        "displayName": {
          "type": "string",
          "description": "User displayed name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Primary verified email address"
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "Public profile picture link"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Account registration timestamp"
        }
      },
      "required": ["uid", "displayName", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile records containing critical identifying information"
    }
  }
}
