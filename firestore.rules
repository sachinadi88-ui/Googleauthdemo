rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global lock default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation helper for User record
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'photoURL', 'createdAt'])
        && data.keys().size() == 5
        && data.uid is string && data.uid.size() <= 128
        && data.displayName is string && data.displayName.size() <= 200
        && data.email is string && data.email.size() <= 320
        && data.photoURL is string && data.photoURL.size() <= 2048
        && data.createdAt is timestamp;
    }

    // Match block for the users collection
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) 
                     && incoming().createdAt == existing().createdAt
                     && incoming().uid == existing().uid;
      allow delete: if false; // Prevent Client deletion of user accounts
    }
  }
}
